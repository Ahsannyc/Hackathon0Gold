# ===================================================
# ENVIRONMENT VARIABLES - COPY TO .env AND FILL IN
# ===================================================
# DO NOT commit .env file - it contains secrets!
# .env is in .gitignore and never pushed to GitHub

# --- PostgreSQL & Odoo Credentials ---
# Generate strong passwords and enter here
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_USER=odoo
POSTGRES_DB=hackathon0_business

# Odoo master password for admin access
ODOO_MASTER_PASSWORD=YOUR_SECURE_MASTER_PASSWORD_HERE

# --- Gmail OAuth Setup ---
# Create OAuth 2.0 credentials in Google Cloud Console
# https://console.cloud.google.com/
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_PATH=watchers/.gmail_token.json

# --- Twilio WhatsApp Sandbox ---
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# --- Twitter/X API ---
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# --- Facebook/Instagram ---
FACEBOOK_ACCESS_TOKEN=your_access_token_here
FACEBOOK_PAGE_ID=your_page_id_here

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# --- Development Settings ---
DEBUG=false
LOG_LEVEL=INFO
